# Supabase — proyecto "personal-hub" (org Fernando-Personal).
# Las dos NEXT_PUBLIC_ son valores publicos (viajan al browser): se pueden commitear.
# Si estas dos estan seteadas, la app usa el adapter real; si no, cae en el placeholder.
NEXT_PUBLIC_SUPABASE_URL=https://chytzzgharuncthfzenx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ApJYeP3D5HymrUS3ISpW6g_RPOekbE8
# Service role: SECRETO, bypassa RLS. NO commitear. Cargar solo en local (.env.local)
# o en el dashboard de Vercel si algun dia hace falta. La app hoy NO lo necesita
# (la escritura del admin usa la sesion del usuario, protegida por RLS).
SUPABASE_SERVICE_ROLE_KEY=

# URL del sitio, para el redirect del magic link (en local http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bot de Telegram (fase 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# IA gratuita para el bot (Gemini o Groq — elegir una)
GEMINI_API_KEY=
GROQ_API_KEY=
